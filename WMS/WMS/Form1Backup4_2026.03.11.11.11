        public static bool IsNullOrEmpty2(ConcurrentDictionary<string, string> Dictionary)
        {
            return (Dictionary == null || Dictionary.Count < 1);
        }

        /// <summary>
        /// ????? 4 ????? + BigEndianUnicode ??? JSON?????? PC/Android ????? JSON?
        /// </summary>
        /// <param name="socket">?? Socket</param>
        /// <param name="data">?????????? JSON?</param>
        private void SendUnifiedResponse(Socket socket, string data)
        {
            if (socket == null || !socket.Connected || string.IsNullOrEmpty(data)) return;

            try
            {
                // 1. ? BigEndianUnicode ?????
                byte[] dataBytes = Encoding.BigEndianUnicode.GetBytes(data);
                // 2. ?? 4 ??????????
                int dataSize = dataBytes.Length;
                byte[] lengthBytes = BitConverter.GetBytes(dataSize);
                if (BitConverter.IsLittleEndian)
                {
                    Array.Reverse(lengthBytes); // ?????
                }
                // 3. ????????
                //socket.Send(lengthBytes, 2, SocketFlags.None);
                socket.Send(lengthBytes, 0,4, SocketFlags.None);
                socket.Send(dataBytes,0, dataBytes.Length, SocketFlags.None);
                Console.WriteLine($"SendUnifiedResponse DataSize={dataSize} Data={data}");
            }
            catch (Exception ex)
            {
                Console.WriteLine($"SendUnifiedResponse ErrorMessage:{ex.Message}");
            }
        }

        /// <summary>
        /// ??????? JSON?????????? ASCII ???
        /// </summary>
        /// <typeparam name="T">????</typeparam>
        /// <param name="obj">???????</param>
        /// <returns>JSON ??</returns>
        /// <summary>Returns a user-friendly message for database-related exceptions (e.g. login failure).</summary>
        private static string GetDbErrorMessage(Exception ex)
        {
            if (ex == null) return "Operation failed.";
            var sqlEx = ex as SqlException;
            if (sqlEx != null && ex.Message != null && ex.Message.IndexOf("Login failed", StringComparison.OrdinalIgnoreCase) >= 0)
                return "Database login failed. Please check WMS server database settings (DataSource, User, Password).";
            return "Operation failed: " + ex.Message;
        }

        private string SerializeToJson<T>(T obj)
        {
            return JsonConvert.SerializeObject(obj, new JsonSerializerSettings()
            {
                StringEscapeHandling = StringEscapeHandling.EscapeNonAscii,
                NullValueHandling = NullValueHandling.Ignore
            });
        }

        /// <summary>
        /// 从数据中取第一个对象（兼容单个对象/List集合/空对象）
        /// </summary>
        private object GetFirstItemFromData(object data, Type entityType)
        {
            // 处理空对象
            if (data == null)
            {
                return Activator.CreateInstance(entityType); // 返回空实例（用于查询所有）
            }

            // 单个对象
            if (data.GetType() == entityType)
            {
                return data;
            }

            // List集合
            if (data is IList list && list.Count > 0)
            {
                return list[0];
            }

            // 默认返回空实例
            return Activator.CreateInstance(entityType);
        }

        /// <summary>
        /// 自动反序列化：兼容单个对象/List集合/空对象
        /// </summary>
        private object DeserializeAuto(Type entityType, string json)
        {
            try
            {
                // 处理空对象（{}）
                if (json.Trim() == "{}")
                {
                    Console.WriteLine("反序列化：空对象（查询所有）");
                    return Activator.CreateInstance(entityType);
                }

                // 尝试单个对象
                object singleObj = JsonConvert.DeserializeObject(json, entityType);
                if (singleObj != null)
                {
                    Console.WriteLine($"反序列化成功：单个{entityType.Name}对象");
                    return singleObj;
                }
            }
            catch
            {
                // 尝试List集合
                Type listType = typeof(List<>).MakeGenericType(entityType);
                object listObj = JsonConvert.DeserializeObject(json, listType);
                if (listObj != null)
                {
                    Console.WriteLine($"反序列化成功：List<{entityType.Name}>集合");
                    return listObj;
                }
            }
            return null;
        }

    }
}

