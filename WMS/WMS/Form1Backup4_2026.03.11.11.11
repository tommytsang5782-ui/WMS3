            }
            finally
            {
                RemoveListBox(RemoteEndPointtxt);
                // ????
                try { sr?.Close(); } catch { }
                try { sw?.Close(); } catch { }
                try { ns?.Close(); } catch { }
                try { socketClient?.Close(); } catch { }

                MsgTxt = null;
            }
