<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingLeft="5dp"
    android:paddingTop="5dp"
    android:paddingRight="5dp"
    android:paddingBottom="5dp"
    android:focusable="true"
    android:layout_gravity="center"
    android:gravity="center"
    android:focusableInTouchMode="true" >


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/textView76"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:layout_weight="1"
            android:textColor="@color/black"
            android:textSize="28sp" />

        <ImageButton
            android:id="@+id/button11"
            android:layout_width="35dp"
            android:layout_height="40dp"
            android:scaleType="centerCrop"
            android:scrollbarSize="0dp"
            app:srcCompat="@drawable/ic_dialog_close_light" />
    </LinearLayout>

    <TextView
        android:id="@+id/textView79"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="#000000"
        android:text="TextView" />

    <TextView
        android:id="@+id/textView77"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Carton Label"
        android:textColor="@color/black"
        android:textSize="18sp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingLeft="10dp">

        <TextView
            android:id="@+id/textView75"
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal|center_vertical"
            android:layout_weight="1"
            android:text="Big"
            android:textColor="@color/black"
            android:textSize="18sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="5dp"
            android:layout_marginRight="5dp"
            android:background="@drawable/scan_label_setting_linearlayout"
            android:orientation="horizontal"
            android:paddingLeft="10dp"
            android:paddingTop="1dp"
            android:paddingRight="5dp"
            android:paddingBottom="1dp">

            <Button
                android:id="@+id/button2"
                android:layout_width="35dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal|center_vertical"
                android:padding="0dp"
                android:text="—"
                android:textAlignment="center"
                android:textAllCaps="false"
                android:textSize="20sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/editText76"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal|center_vertical"
                android:layout_weight="1"
                android:gravity="center"
                android:paddingLeft="10dp"
                android:paddingRight="10dp"
                android:text="0"
                android:textColor="@color/black"
                android:textSize="20sp"
                android:inputType="number" />

            <Button
                android:id="@+id/button3"
                android:layout_width="35dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal|center_vertical"
                android:padding="0dp"
                android:text="＋"
                android:textAlignment="center"
                android:textAllCaps="false"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingLeft="10dp">

        <TextView
            android:id="@+id/textView78"
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal|center_vertical"
            android:text="Small"
            android:textColor="@color/black"
            android:textSize="18sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="5dp"
            android:layout_marginRight="5dp"
            android:background="@drawable/scan_label_setting_linearlayout"
            android:orientation="horizontal"
            android:paddingLeft="10dp"
            android:paddingTop="1dp"
            android:paddingRight="5dp"
            android:paddingBottom="1dp">

            <Button
                android:id="@+id/button4"
                android:layout_width="35dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal|center_vertical"
                android:padding="0dp"
                android:text="—"
                android:textAlignment="center"
                android:textAllCaps="false"
                android:textSize="20sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/editText79"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal|center_vertical"
                android:layout_weight="1"
                android:gravity="center"
                android:paddingLeft="10dp"
                android:paddingRight="10dp"
                android:text="0"
                android:textColor="@color/black"
                android:textSize="20sp"
                android:inputType="number" />

            <Button
                android:id="@+id/button5"
                android:layout_width="35dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal|center_vertical"
                android:padding="0dp"
                android:text="＋"
                android:textAlignment="center"
                android:textAllCaps="false"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

    <TextView
        android:id="@+id/textView80"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Label"
        android:textColor="@color/black"
        android:textSize="18sp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingLeft="10dp">

        <TextView
            android:id="@+id/textView81"
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:text="Big"
            android:textColor="@color/black"
            android:textSize="18sp" />

        <ImageButton
            android:id="@+id/button6"
            android:layout_width="40dp"
            android:layout_height="match_parent"
            android:scaleType="center"
            android:background="#00000000"
            android:src="@drawable/ic_baseline_remove_circle_outline_24" />

        <EditText
            android:id="@+id/editText82"
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="@color/black"
            android:textSize="20sp"
            android:gravity="center"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:background="@drawable/scan_label_setting_linearlayout"
            android:inputType="number" />

        <ImageButton
            android:id="@+id/button7"
            android:layout_width="40dp"
            android:layout_height="match_parent"
            android:padding="0dp"
            android:scaleType="center"
            android:background="#00000000"
            android:src="@drawable/ic_baseline_add_circle_outline_24" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingLeft="10dp">

        <TextView
            android:id="@+id/textView83"
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:text="Small"
            android:textColor="@color/black"
            android:textSize="18sp" />

        <ImageButton
            android:id="@+id/button8"
            android:layout_width="40dp"
            android:layout_height="match_parent"
            android:padding="0dp"
            android:scaleType="center"
            android:background="#00000000"
            android:src="@drawable/ic_baseline_remove_circle_outline_24" />

        <EditText
            android:id="@+id/editText84"
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="@color/black"
            android:textSize="20sp"
            android:gravity="center"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:background="@drawable/scan_label_setting_linearlayout"
            android:inputType="number" />

        <ImageButton
            android:id="@+id/button9"
            android:layout_width="40dp"
            android:layout_height="match_parent"
            android:padding="0dp"
            android:scaleType="center"
            android:background="#00000000"
            android:src="@drawable/ic_baseline_add_circle_outline_24" />
    </LinearLayout>

    <Button
        android:id="@+id/button10"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:backgroundTint="@color/Green_2"
        android:text="Save" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/scan_label_setting_BottomMenu"
        android:layout_width="320dp"
        android:layout_height="wrap_content"
        app:menu="@menu/scan_label_setting_bottom_menu" />

</LinearLayout>