<?xml version="1.0" encoding="utf-8"?>
    <layer-list xmlns:android="http://schemas.android.com/apk/res/android" >
        <!-- 連框顏色值 -->
        <item>
            <shape>
                <solid android:color="#cccccc" />
            </shape>
        </item>
        <!-- 主體背景顏色值 -->
        <item android:bottom="2dp"
            android:top="2dp"
            android:left="2dp"
            android:right="2dp">
            <shape>
                <solid android:color="#ffffff" />
                <padding android:bottom="2dp"
                    android:left="2dp"
                    android:right="2dp"
                    android:top="2dp" />
            </shape>
        </item>
    </layer-list>
